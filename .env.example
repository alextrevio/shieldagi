# ShieldAGI 2.0 — Environment Configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════
# REQUIRED: AI Provider
# ═══════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ═══════════════════════════════════════════════
# REQUIRED: Target Platform (set per scan)
# ═══════════════════════════════════════════════
TARGET_REPO_URL=https://github.com/user/repo
TARGET_DOMAIN=yourdomain.com
# TARGET_SSH_KEY_PATH=~/.ssh/id_rsa  # Optional: for infrastructure scanning

# ═══════════════════════════════════════════════
# Supabase Target (if applicable)
# ═══════════════════════════════════════════════
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key  # For RLS validation

# ═══════════════════════════════════════════════
# GitHub Integration (for PR creation)
# ═══════════════════════════════════════════════
GITHUB_TOKEN=ghp_your-token-here
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# ═══════════════════════════════════════════════
# Notification Channels
# ═══════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ═══════════════════════════════════════════════
# Redis (for rate limiting in Chain Walls)
# ═══════════════════════════════════════════════
REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_URL=https://your-upstash.upstash.io
# UPSTASH_REDIS_TOKEN=your-upstash-token

# ═══════════════════════════════════════════════
# Infrastructure
# ═══════════════════════════════════════════════
SHIELDAGI_MODE=production  # production | development | sandbox
SANDBOX_NETWORK=172.28.0.0/16
OPENFANG_DASHBOARD_PORT=4200
GRAFANA_PORT=3000

# ═══════════════════════════════════════════════
# Scan Configuration
# ═══════════════════════════════════════════════
MAX_SCAN_DURATION=3600      # Max seconds per scan phase
NMAP_TIMEOUT=300            # Max seconds for nmap scans
SQLMAP_LEVEL=3              # sqlmap level (1-5)
SQLMAP_RISK=2               # sqlmap risk (1-3)
SENTINEL_INTERVAL_MINUTES=5 # How often Sentinel checks
DEP_GUARDIAN_INTERVAL_HOURS=6

# ═══════════════════════════════════════════════
# Rate Limiting Defaults (Chain Walls)
# ═══════════════════════════════════════════════
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=60
RATE_LIMIT_PUBLIC_MAX=30
RATE_LIMIT_PUBLIC_WINDOW=60
